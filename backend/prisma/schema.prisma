generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = 5
  output               = "../app/db/prisma_client"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id             String      @id @default(uuid())
  email          String      @unique
  passwordHash   String?     // Renamed to match frontend client-side expectations
  firstName      String?
  lastName       String?
  image          String?     // Added for social profiles
  provider       String?     // Added to track 'google', 'apple', or 'credentials'
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  documents      Document[]
}

model Document {
  id               String       @id @default(uuid())
  title            String
  filename         String
  uploadDate       DateTime     @default(now())
  riskScore        Float?
  status           String       @default("PROCESSING")
  userId           String
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  clauses          Clause[]
  negotiationMsg   String?      
  errorMessage     String?      
}

model Clause {
  id               String       @id @default(uuid())
  documentId       String
  document         Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  originalText     String       
  simplifiedText   String?
  clauseType       String       
  riskLevel        String       
  severityScore    Float        
}
